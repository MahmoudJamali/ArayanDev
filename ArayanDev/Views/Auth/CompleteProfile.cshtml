@model Business.Handlers.UserProfiles.Commands.CompleteProfileModel


@{
    ViewData["Title"] = "تکمیل پروفایل";
}

<div class="container py-5" style="max-width:700px">

    <div class="card shadow border-0">
        <div class="card-body p-4">

            <h3 class="text-center mb-4 fw-bold">
                تکمیل پروفایل کاربری
            </h3>

            <form asp-controller="Auth"
                  asp-action="CompleteProfile"
                  asp-route-returnUrl="@ViewBag.ReturnUrl"
                  method="post"
                  enctype="multipart/form-data">


                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <!-- Name -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label">نام</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Family -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Family" class="form-label">نام خانوادگی</label>
                        <input asp-for="Family" class="form-control" />
                        <span asp-validation-for="Family" class="text-danger"></span>
                    </div>

                    <!-- NationalCode -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="NationalCode" class="form-label">کد ملی</label>
                        <input asp-for="NationalCode" class="form-control" maxlength="10" />
                        <span asp-validation-for="NationalCode" class="text-danger"></span>
                    </div>


                    <!-- BirthDay -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">تاریخ تولد</label>

                        <div class="row g-2">
                            <div class="col-4">
                                <select asp-for="BirthDayDay" class="form-select">
                                    <option value="">روز</option>
                                    @for (int day = 1; day <= 31; day++)
                                    {
                                        <option value="@day">@day</option>
                                    }
                                </select>
                            </div>

                            <div class="col-4">
                                <select asp-for="BirthDayMonth" class="form-select">
                                    <option value="">ماه</option>
                                    <option value="1">فروردین</option>
                                    <option value="2">اردیبهشت</option>
                                    <option value="3">خرداد</option>
                                    <option value="4">تیر</option>
                                    <option value="5">مرداد</option>
                                    <option value="6">شهریور</option>
                                    <option value="7">مهر</option>
                                    <option value="8">آبان</option>
                                    <option value="9">آذر</option>
                                    <option value="10">دی</option>
                                    <option value="11">بهمن</option>
                                    <option value="12">اسفند</option>
                                </select>
                            </div>

                            <div class="col-4">
                                <select asp-for="BirthDayYear" class="form-select">
                                    <option value="">سال</option>
                                    @for (int year = 1405; year >= 1320; year--)
                                    {
                                        <option value="@year">@year</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <span asp-validation-for="BirthDayDay" class="text-danger d-block"></span>
                        <span asp-validation-for="BirthDayMonth" class="text-danger d-block"></span>
                        <span asp-validation-for="BirthDayYear" class="text-danger d-block"></span>

                        @if (ViewData.ModelState["BirthDay"]?.Errors.Count > 0)
                        {
                            <span class="text-danger d-block">
                                @ViewData.ModelState["BirthDay"]?.Errors.First().ErrorMessage
                            </span>
                        }
                    </div>


                    <!-- City -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="City" class="form-label">شهر</label>
                        <input asp-for="City" class="form-control" />
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>

                    <!-- Education -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="EducationDegree" class="form-label">مدرک تحصیلی</label>
                        <input asp-for="EducationDegree" class="form-control" />
                        <span asp-validation-for="EducationDegree" class="text-danger"></span>
                    </div>

                    <!-- Major -->
                    <div class="col-md-12 mb-3">
                        <label asp-for="Major" class="form-label">رشته تحصیلی</label>
                        <input asp-for="Major" class="form-control" />
                        <span asp-validation-for="Major" class="text-danger"></span>
                    </div>
                    <!-- Address -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Address" class="form-label">آدرس</label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <!-- Email -->
                    <div class="col-md-12 mb-3">
                        <label asp-for="Email" class="form-label">ایمیل (اختیاری)</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                  

                    <div class="col-md-12 text-center mb-3">
                        <div style="width:200px;height:200px;border-radius:50%;overflow:hidden;
                border:2px solid #ddd;margin:auto;background:#f8f9fa;">
                            <img id="imagePreview"
                                 src="/images/default-avatar.png"
                                 style="width:100%;height:100%;object-fit:cover;display:none;" />
                            <span id="previewText" style="color:#888;">پیش‌نمایش عکس</span>
                        </div>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="ProfileImage" class="form-label">عکس پروفایل</label>
                        <input asp-for="ProfileImage"
                               id="profileImageInput"
                               type="file"
                               class="form-control"
                               accept="image/*" />
                        <span asp-validation-for="ProfileImage" class="text-danger"></span>
                    </div>

                </div>
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <button type="submit" class="btn btn-primary w-100 mt-3 py-2 fw-bold">
                    ذخیره اطلاعات
                </button>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById('profileImageInput')
            .addEventListener('change', function (event) {

                const file = event.target.files[0];
                const preview = document.getElementById('imagePreview');
                const previewText = document.getElementById('previewText');

                if (!file) {
                    preview.src = '';
                    preview.style.display = 'none';
                    previewText.style.display = 'block';
                    return;
                }

                const reader = new FileReader();

                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    previewText.style.display = 'none';
                };

                reader.readAsDataURL(file);
            });
    </script>
}
