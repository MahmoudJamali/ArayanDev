<style>
    /* عکس یک‌سوم ارتفاع */
    .course-img-top {
        height: 220px !important;
        object-fit: cover;
        border-radius: .75rem .75rem 0 0;
    }

    /* متن دوره */
    .course-content {
        direction: rtl;
        text-align: right;
        line-height: 2;
        font-size: 15px;
        color: #444;
    }

        .course-content p {
            margin-bottom: 18px;
        }

        .course-content ul {
            padding-right: 20px;
            margin-bottom: 20px;
        }

        .course-content li {
            margin-bottom: 8px;
        }

    .section-title {
        font-weight: 800;
        color: #6f42c1;
        margin-bottom: 10px;
        display: block;
        font-size: 17px;
    }

    .highlight-box {
        background: #f8f6ff;
        border-right: 4px solid #6f42c1;
        padding: 15px 18px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    /* باکس قوانین */
    #rules-box {
        background: #f3f3ff;
        border: 1px solid #d8d6ff;
    }

        #rules-box label {
            font-size: 15px;
            cursor: pointer;
        }

</style>

@model CourseDetailsViewModel

<div class="container my-5 text-end" dir="rtl">

    <div class="row justify-content-center">

        <div class="col-lg-7 col-md-9">

            <div class="card shadow-lg border-0" style="border-radius: 15px;">

                <!-- تصویر -->
                <img src="/assets/img/course/course2.jpg"
                     class="course-img-top"
                     alt="@Model.Course.Title">

                <div class="card-body px-4 py-5">

                    <!-- عنوان -->
                    <h3 class="fw-bold text-center mb-4" style="color:#333;">
                        @Model.Course.Title
                    </h3>

                    <!-- توضیحات -->
                    <div class="course-content">

                        <p style="text-align: justify; direction: rtl;">
                            در این دوره با فراگیری آموزش‌ها لازم، قادر به طراحی وب‌سایت و اپلیکیشن در پلتفرم Asp.Net خواهید شد.
                            برای رسیدن به این هدف شما نیازمند یادگیری موارد زیر هستید:
                        </p>


                        <ul>
                            <li>زبان برنامه‌نویسی پیشرفته #C</li>
                            <li>مفاهیم داده و SQL</li>
                            <li>MVC – Razor – Entity Framework</li>
                            <li>سایر مفاهیم تخصصی و پیشرفته</li>
                        </ul>

                        <div class="highlight-box">
                            <span class="section-title">نحوه برگزاری دوره</span>

                            <p>
                                <i class="fas fa-check-circle me-1"></i>یک جلسه برای سطح‌سنجی برگزار می‌شود.<br>
                                <i class="fas fa-check-circle me-1"></i>دوره در سه سطح مقدماتی، میانی و پیشرفته برگزار می‌گردد.<br>
                                <i class="fas fa-check-circle me-1"></i>هر سطح طی 15 جلسه برگزار می‌گردد.<br>
                                <i class="fas fa-check-circle me-1"></i>کلاس‌ها به صورت آنلاین یا حضوری بنا به انتخاب شما برگزار می‌شود.<br>
                                <i class="fas fa-check-circle me-1"></i>مدت هر جلسه 70 دقیقه است.<br>
                                <i class="fas fa-check-circle me-1"></i>هر هفته سه جلسه برگزار می‌شود.
                            </p>
                        </div>

                        <div class="highlight-box">
                            <span class="section-title">هزینه جلسات</span>

                            <p>
                                هزینه هر جلسه حضوری 850 و هر جلسه آنلاین 750 هزار تومان می‌باشد.<br>
                                پرداخت پس از پایان هر جلسه انجام می‌شود.<br>
                            </p>
                        </div>
                    </div>


                    <!-- 🔻🔻 بخش تیک قوانین - فقط اگر ثبت نام نکرده باشد 🔻🔻 -->
                    @if (!Model.IsEnrolled)
                    {
                        <div class="mt-4 p-3 border rounded text-end" id="rules-box"
                             style="background-color: #f3e8ff;">

                            <!-- هشدار -->
                            <div class="d-flex flex-row-reverse align-items-center gap-2 justify-content-end w-100">

                                <span style="color: blueviolet;">لطفاً قوانین دوره را مطالعه و تأیید نمایید.</span>
                                <span style="color: darkmagenta;">⚠</span>
                            </div>

                            <!-- چک‌باکس عادی -->
                            <div class="d-flex flex-row-reverse align-items-center gap-2 justify-content-end w-100">

                                <input class="form-check-input" type="checkbox" id="acceptRules" />

                                <label class="form-check-label fw-bold" for="acceptRules">
                                    تایید می‌نمایم
                                </label>

                            </div>

                        </div>

                    }





                    <!-- 🔺🔺 پایان بخش قوانین 🔺🔺 -->
                    <!-- دکمه ثبت‌نام -->
                    <div class="d-flex justify-content-center mt-4">

                        @if (Model.IsEnrolled)
                        {
                            <button class="btn btn-success enrolled-btn px-4" disabled>
                                شما قبلاً با موفقیت در این دوره شرکت کرده‌اید
                                <i class="fas fa-check-circle me-1"></i>
                            </button>
                        }
                        else
                        {
                            <a id="enrollBtn"
                               class="btn btn-primary px-5 py-2 disabled"
                               style="pointer-events:none; opacity:0.55; font-size:16px; font-weight:600;"
                               href="@Url.Action("Enroll", "Course", new { courseId = Model.Course.Id })">
                                ثبت‌نام در دوره
                            </a>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>




<!-- اسکریپت فعال‌سازی دکمه بعد از تیک زدن -->
<script>
    const checkbox = document.getElementById("acceptRules");
    const enrollBtn = document.getElementById("enrollBtn");
    const rulesWarning = document.getElementById("rulesWarning");

    if (checkbox) {

        checkbox.addEventListener("change", function () {
            if (this.checked) {
                enrollBtn.classList.remove("disabled");
                enrollBtn.style.pointerEvents = "auto";
                enrollBtn.style.opacity = "1";
                rulesWarning.classList.add("d-none");
            } else {
                enrollBtn.classList.add("disabled");
                enrollBtn.style.pointerEvents = "none";
                enrollBtn.style.opacity = "0.55";
            }
        });

        enrollBtn.addEventListener("click", function (e) {
            if (!checkbox.checked) {
                e.preventDefault();
                rulesWarning.classList.remove("d-none");
            }
        });

    }
</script>
