@{
    ViewData["Title"] = "ورود";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />

    <style>

        body {
            margin: 0;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: tahoma;
            background: linear-gradient(140deg,#eef2ff,#ffffff);
        }

        /* کارت */
        .login-card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            padding: 40px 28px;
            border-radius: 22px;
            box-shadow: 0 20px 45px rgba(0,0,0,0.08);
            border: 1px solid #f1f1f1;
        }

            /* تیتر */
            .login-card h3 {
                text-align: center;
                margin-bottom: 30px;
                font-weight: 700;
                color: #3a0ca3;
            }

        /* ورودی */
        .phone-input {
            width: 100%;
            height: 46px;
            border-radius: 12px;
            border: 1px solid #ddd;
            padding: 0 15px;
            font-size: 15px;
            text-align: center;
            transition: all .25s;
        }

            .phone-input:focus {
                border-color: #6a11cb;
                outline: none;
                box-shadow: 0 0 0 3px rgba(106,17,203,.12);
            }

        /* دکمه */
        .send-btn {
            width: 100%;
            height: 46px;
            margin-top: 20px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(45deg,#6a11cb,#2575fc);
            color: #fff;
            font-size: 15px;
            font-weight: 600;
            transition: .25s;
        }

            .send-btn:hover {
                opacity: .9;
            }

        /* متن راهنما */
        .login-help {
            text-align: center;
            font-size: 13px;
            margin-top: 18px;
            color: #777;
        }

        /* ریسپانسیو موبایل */
        @@media (max-width:480px) {
            body

        {
            padding: 15px;
        }

        .login-card {
            padding: 30px 20px;
            border-radius: 18px;
        }

            .login-card h3 {
                font-size: 20px;
            }

        }
    </style>
</head>

<body>

    <div class="login-card">

        <h3>ورود به حساب</h3>

        <form asp-action="SendOtp" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">

            <div class="mb-3">
                <input id="phone"
                       class="phone-input"
                       type="text"
                       name="phoneNumber"
                       placeholder="شماره موبایل (مثلاً 09123456789)"
                       maxlength="11"
                       required />
            </div>

            <button class="send-btn" type="submit">
                ارسال کد تأیید
            </button>

        </form>

        <div class="login-help">
            کد تأیید برای شما پیامک خواهد شد
        </div>

    </div>


    <script src="/assets/js/vendor/jquery-3.6.0.min.js"></script>
    <script src="/assets/js/bootstrap.min.js"></script>

    <script>

        const phoneInput=document.getElementById("phone");

        phoneInput.addEventListener("input",function(){

        let v=this.value.replace(/[^0-9]/g,"");

        if(v.length>0 && v[0]!=="0"){
        v="0";
        }

        if(v.length>11){
        v=v.slice(0,11);
        }

        this.value=v;

        });

        document.querySelector("form").addEventListener("submit",function(e){

        if(phoneInput.value.length!==11){

        alert("شماره موبایل باید 11 رقمی باشد");

        e.preventDefault();

        }

        });

    </script>

</body>
</html>
