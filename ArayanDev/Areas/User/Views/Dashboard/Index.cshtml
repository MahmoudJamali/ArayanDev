@using Business.Handlers.Users.Queries
@model UserDashboardViewModel
@using System.Globalization
@using Entities.Enums

@{
    string birthDateShamsi = "";

    if (Model.BirthDay != default)
    {
        var pc = new PersianCalendar();
        var date = Model.BirthDay.ToDateTime(TimeOnly.MinValue);

        birthDateShamsi = $"{pc.GetYear(date)}/{pc.GetMonth(date):00}/{pc.GetDayOfMonth(date):00}";
    }
}
@if (string.IsNullOrEmpty(Model.Name))
{
    <div class="alert alert-warning mb-4">
        لطفا اطلاعات پروفایل خود را تکمیل کنید.
        <a asp-area="User"
           asp-controller="Dashboard"
           asp-action="EditProfile"
           class="btn btn-sm btn-warning ms-2">
            تکمیل اطلاعات
        </a>
    </div>
}

<div class="card mb-4 shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">
        <span>اطلاعات کاربری</span>

        <form asp-area="User"
              asp-controller="Dashboard"
              asp-action="EditProfile"
              method="get">

            <button type="submit" class="btn btn-sm btn-primary">
                ویرایش اطلاعات
            </button>

        </form>

    </div>

    <div class="card-body">

        <div class="row">

            <div class="col-md-4 mb-3">
                <strong>نام:</strong>
                <div>@Model.Name</div>
            </div>

            <div class="col-md-4 mb-3">
                <strong>نام خانوادگی:</strong>
                <div>@Model.Family</div>
            </div>

            <div class="col-md-4 mb-3">
                <strong>شماره موبایل:</strong>
                <div>@Model.PhoneNumber</div>
            </div>

            <div class="col-md-4 mb-3">
                <strong>کد ملی:</strong>
                <div>@Model.NationalCode</div>
            </div>

            <div class="col-md-4 mb-3">
                <strong>شهر:</strong>
                <div>@Model.City</div>
            </div>

            <div class="col-md-4 mb-3">
                <strong>تاریخ تولد:</strong>
                <div>@birthDateShamsi</div>
            </div>

            <div class="col-md-4 mb-3">
                <strong>مدرک تحصیلی:</strong>
                <div>@Model.EducationDegree</div>
            </div>

            <div class="col-md-4 mb-3">
                <strong>رشته:</strong>
                <div>@Model.Major</div>
            </div>

            <div class="col-md-4 mb-3">
                <strong>ایمیل:</strong>
                <div>@Model.Email</div>
            </div>

        </div>

    </div>

</div>

<div class="card shadow-sm">

    <div class="card-header">
        دوره‌های ثبت نام شده
    </div>

    <div class="card-body">

        @if (!Model.Courses.Any())
        {
            <div class="alert alert-info">
                شما هنوز در دوره‌ای ثبت نام نکرده‌اید
            </div>
        }
        else
        {
            <table class="table table-striped">

                <thead>
                    <tr>
                        <th>عنوان دوره</th>
                        <th>نوع دوره</th>
                        <th>قیمت</th>
                        <th>تاریخ شروع</th>
                        <th>تاریخ ثبت نام</th>
                    </tr>
                </thead>

                <tbody>

                    @{
                        var pc = new PersianCalendar();
                    }

                    @foreach (var item in Model.Courses)
                    {
                        string startDateShamsi = "-";
                        string enrollDateShamsi = "-";

                        if (item.StartDate.HasValue)
                        {
                            var sd = item.StartDate.Value;
                            startDateShamsi =
                            $"{pc.GetYear(sd)}/{pc.GetMonth(sd):00}/{pc.GetDayOfMonth(sd):00}";
                        }

                        var ed = item.EnrollDate;
                        enrollDateShamsi =
                        $"{pc.GetYear(ed)}/{pc.GetMonth(ed):00}/{pc.GetDayOfMonth(ed):00}";

                        <tr>

                            <td>@item.Title</td>

                            <td>
                                @(item.CourseType == CourseType.InPerson
                                    ? "حضوری"
                                    : "آنلاین")
                            </td>

                            <td>
                                @(item.IsFree ? "رایگان" : item.Price.ToString("N0"))
                            </td>

                            <td>@startDateShamsi</td>

                            <td>@enrollDateShamsi</td>

                        </tr>
                    }

                </tbody>


            </table>
        }

    </div>

</div>
