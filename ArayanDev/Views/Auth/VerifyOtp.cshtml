@model string

@{
    ViewData["Title"] = "تأیید کد";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />

    <style>

        body {
            margin: 0;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: tahoma;
            background: linear-gradient(140deg,#eef2ff,#ffffff);
        }

        /* کارت */
        .verify-card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            padding: 40px 28px;
            border-radius: 22px;
            box-shadow: 0 20px 45px rgba(0,0,0,0.08);
            border: 1px solid #f1f1f1;
            text-align: center;
        }

            /* تیتر */
            .verify-card h3 {
                margin-bottom: 10px;
                font-weight: 700;
                color: #3a0ca3;
            }

        /* شماره موبایل */
        .phone-label {
            font-size: 14px;
            margin-bottom: 25px;
            color: #666;
        }

            .phone-label strong {
                display: block;
                margin-top: 5px;
                color: #222;
                font-size: 15px;
            }

        /* ورودی OTP */
        .otp-input {
            width: 100%;
            height: 48px;
            border-radius: 12px;
            border: 1px solid #ddd;
            background: #fff;
            font-size: 22px;
            text-align: center;
            letter-spacing: 10px;
            transition: .25s;
        }

            .otp-input:focus {
                border-color: #2575fc;
                outline: none;
                box-shadow: 0 0 0 3px rgba(37,117,252,.15);
            }

        /* دکمه تایید */
        .action-btn {
            width: 100%;
            height: 46px;
            margin-top: 20px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(45deg,#6a11cb,#2575fc);
            color: #fff;
            font-size: 15px;
            font-weight: 600;
        }

        /* تایمر */
        .timer {
            margin-top: 18px;
            font-size: 14px;
            color: #777;
        }

        /* دکمه ارسال مجدد */
        .resend-btn {
            margin-top: 10px;
            width: 100%;
            height: 42px;
            border-radius: 12px;
            border: 1px solid #2575fc;
            background: #fff;
            color: #2575fc;
            font-size: 14px;
        }

            .resend-btn:disabled {
                opacity: .5;
                border-color: #bbb;
                color: #888;
            }

        /* موبایل */
        @@media (max-width:480px) {
            body

        {
            padding: 15px;
        }

        .verify-card {
            padding: 30px 20px;
            border-radius: 18px;
        }

        .otp-input {
            font-size: 20px;
            letter-spacing: 8px;
        }

        }
    </style>
</head>

<body>

    <div class="verify-card">

        <h3>تأیید کد</h3>

        <div class="phone-label">
            کد ارسال شده به شماره
            <strong>@Model</strong>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-2"></div>

        <form asp-controller="Auth"
              asp-action="VerifyOtp"
              asp-route-returnUrl="@ViewBag.ReturnUrl"
              method="post">

            <input type="hidden" name="phoneNumber" value="@Model" />
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <input type="hidden" id="expireAt" value="@ViewBag.ExpireAt" />

            <input id="otpBox"
                   class="otp-input"
                   type="text"
                   name="otpCode"
                   maxlength="6"
                   placeholder="••••••"
                   autocomplete="one-time-code"
                   required />

            <button type="submit" class="action-btn">
                تأیید
            </button>

        </form>

        <div class="timer">
            زمان باقی‌مانده: <span id="time">120</span> ثانیه
        </div>

        <form asp-controller="Auth"
              asp-action="SendOtp"
              method="post">

            <input type="hidden" name="phoneNumber" value="@Model" />

            <button id="resendBtn"
                    type="submit"
                    class="resend-btn"
                    disabled>
                ارسال مجدد کد
            </button>

        </form>

    </div>

    <script src="/assets/js/vendor/jquery-3.6.0.min.js"></script>
    <script src="/assets/js/bootstrap.min.js"></script>

    <script>

        const expireAt = new Date(document.getElementById("expireAt").value).getTime();
        const timeEl = document.getElementById("time");
        const resendBtn = document.getElementById("resendBtn");

        function updateTimer(){

        const now = new Date().getTime();
        const remaining = Math.floor((expireAt - now) / 1000);

        if(remaining <= 0){
        timeEl.innerText = "0";
        resendBtn.disabled = false;
        }
        else{
        timeEl.innerText = remaining;
        }

        }

        updateTimer();
        setInterval(updateTimer,1000);

    </script>

</body>
</html>
