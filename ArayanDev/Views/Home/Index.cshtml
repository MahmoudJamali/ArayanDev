<!--==============================
Hero Area
==============================-->
<div class="th-hero-wrapper hero-1" id="hero">
    <div class="hero-slider-1 th-carousel" data-fade="true" data-slide-show="1" data-md-slide-show="1" data-dots="true">


        <div class="th-hero-slide">
            <div class="th-hero-bg" data-overlay="title" data-opacity="4" data-bg-src="/assets/img/hero/Arayan-Hero2.jpg"></div>
            <div class="container">
                <div class="row align-items-center justify-content-center">
                    <div class="col-md-6">
                        <div class="hero-style1">
                            <h5 class="hero-title top-center-title text-white fw-bolder fs-4" data-ani="slideinleft" data-ani-delay="0.1s">
                                ... Become A Legend
                            </h5>
                            <br />
                            <h1 class="hero-title text-white fw-bolder fs-4" data-ani="slideinleft" data-ani-delay="1.0s">
								آکادمی برنامه نویسی و طراحی سایت آرایان
                            </h1>

                            <h1 class="hero-title text-white fw-bolder fs-1" data-ani="slideinleft" data-ani-delay="2.5s">
                                                           
                            </h1>
                        </div>

                    </div>
                    <div class="col-md-6 text-lg-end text-center">
                        <div class="hero-img1 jump">
                            <img id="heroRandomImg" src="/assets/img/hero/banner2002.jpg" alt="hero">
                        </div>
                    </div>

                </div>
            </div>
            <div class="hero-shape shape1">
                <img src="/assets/img/hero/shape_1_1.png" alt="shape">
            </div>
            <div class="hero-shape shape2">
                <img src="/assets/img/hero/shape_1_2.png" alt="shape">
            </div>
            <div class="hero-shape shape3"></div>

            <div class="hero-shape shape4 shape-mockup jump-reverse" data-right="3%" data-bottom="2%">
                <img src="/assets/img/hero/shape_1_3.png" alt="shape">
            </div>
            <div class="hero-shape shape5 shape-mockup jump-reverse" data-left="0" data-bottom="0">
                <img src="/assets/img/hero/shape_1_4.png" alt="shape">
            </div>
        </div>


    </div>
</div> 
<!--======== / Hero Section ========-->
<!--==============================
About Area
 ==============================-->
 

<div class="overflow-hidden" id="blog-sec" style="padding-top:35px;padding-bottom:35px;">
    <div class="container">
        <div class="row align-items-start" style="direction: rtl;">

            <!-- ستون متن -->
            <div class="col-lg-7">

                <div class="title-area mb-2" style="margin-top:0;">
                    <h5 class="sec-title" style="margin-top:0;">
                        آکادمی برنامه نویسی و طراحی سایت
                        <span class="text-theme">آرایان</span>
                    </h5>
                </div>

                <div style="text-align:justify;font-size:1rem;line-height:2.1;font-weight:400;">

                    <p>

                        <span class="text-theme fw-bold fs-4">آکادمی آرایان</span><br> با هدف ایجاد بستری حرفه‌ای برای آموزش برنامه‌نویسی و طراحی سایت راه‌اندازی شده است. دوره‌های ما از سطح مبتدی تا پیشرفته به‌صورت آنلاین و حضوری برگزار می‌شوند. محور اصلی آموزش ما بر پایه زبان برنامه‌نویسی #C در پلتفرم ASP.NET CORE و محیط ویژوال استودیو می‌باشد.دوره جامع آموزش برنامه نویسی و طراحی سایت در دو سطح مقدماتی و پیشرفته برگزار می گردد . ابتدا در دوره مقدماتی زبان برنامه نویسی  #C  آموزش داده می شود سپس در دوره پیشرفته با آموزش طراحی سایت در پلتفرم ASP.NET در کنار شما هستیم .
                    </p>

                    <p>
						<span class="text-theme fw-bold fs-4">اما چرا #C ؟</span><br>
						زبان #C یکی از معتبرترین زبان‌های برنامه‌نویسی دنیاست که توسط شرکت مایکروسافت توسعه یافته و بر پایه چارچوب قدرتمند NET. کار می‌کند. این زبان با معماری شی‌گرا، امنیت بالا و عملکرد پایدار، برای توسعه نرم‌افزارهای ویندوز، وب‌سایت‌های مدرن و اپلیکیشن‌های موبایل استفاده می‌شود. طبق گزارش‌های معتبر #C همواره در میان محبوب‌ترین زبان‌های برنامه‌نویسی جهان قرار دارد. تقاضای بالا در بازار کار داخلی و بین‌المللی باعث شده برنامه‌نویسان ‎C# فرصت‌های شغلی متنوعی در سازمان ها و ادارات دولتی ، شرکت‌ها، استارتاپ‌ها و پروژه‌های فریلنسری داشته باشند. اگر به دنبال یادگیری یک زبان حرفه‌ای با آینده شغلی قوی هستید،C# یکی از بهترین انتخاب‌ها برای ورود جدی به دنیای برنامه‌نویسی است.

                </div>

               

            </div>

            <!-- ستون تصاویر -->
            <div class="col-lg-5 text-center text-lg-end">

                <div style="display:flex;flex-direction:column;gap:18px;align-items:flex-end;margin-top:0;">

                    <div style="max-width:420px;border-radius:26px;overflow:hidden;box-shadow:0 18px 45px rgba(0,0,0,0.15);">
                        <img src="/assets/img/hero/banner1002.jpg" class="img-fluid" style="display:block;border-radius:26px;">
                    </div>

                </div>

            </div>

        </div>
    </div>
</div>
   

