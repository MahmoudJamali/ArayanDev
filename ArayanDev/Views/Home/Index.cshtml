<script>

const images = [
    "/assets/img/hero/banner2002.jpg",
    "/assets/img/hero/banner2000.jpg",
    "/assets/img/hero/banner2003.jpg"
];

const img = document.getElementById("heroRandomImg");

img.style.transition = "opacity 0.7s ease";

let sliderInterval;
let isPaused = false;
let currentIndex = 0;

function changeHeroImage() {

    img.style.opacity = "0";

    setTimeout(() => {

        currentIndex++;
        if(currentIndex >= images.length){
            currentIndex = 0;
        }

        img.src = images[currentIndex];
        img.style.opacity = "1";

    }, 700);

}

function startSlider(){
    sliderInterval = setInterval(changeHeroImage, 5000);
}

// شروع اسلاید
startSlider();

// توقف / ادامه با کلیک
img.addEventListener("click", function () {

    if(isPaused){
        startSlider();
        isPaused = false;
    } else {
        clearInterval(sliderInterval);
        isPaused = true;
    }

});

</script>

